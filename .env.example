# Required. Arcane Angler uses the login username, not the public profile name.
ARCANE_USERNAME=your-login-username
ARCANE_PASSWORD=your-password

# Optional. When omitted, the first character (normally the main character) is used.
ARCANE_CHARACTER=

# Browser and timing options.
ARCANE_HEADLESS=true
ARCANE_AUTOMATION_ENABLED=true
ARCANE_AUTO_FISHING=true
ARCANE_AUTO_BAIT=false
ARCANE_BAIT_ID=
ARCANE_BAIT_RESTOCK_THRESHOLD=100
ARCANE_BAIT_PURCHASE_QUANTITY=1000
ARCANE_BAIT_CHECK_INTERVAL_MS=30000
# Work/rest schedule. Quiet hours use the Linux server's local time.
ARCANE_ACTIVE_MIN_MINUTES=40
ARCANE_ACTIVE_MAX_MINUTES=70
ARCANE_REST_MIN_MINUTES=5
ARCANE_REST_MAX_MINUTES=15
ARCANE_QUIET_START_HOUR=0
ARCANE_QUIET_END_HOUR=8
ARCANE_AUTO_VERIFY=true
ARCANE_ENFORCE_CLASSIC_MODE=true
ARCANE_URL=https://arcaneangler.com/
ARCANE_USER_DATA_DIR=.data/browser
ARCANE_ARTIFACTS_DIR=artifacts
ARCANE_CLICK_DELAY_MIN_MS=250
ARCANE_CLICK_DELAY_MAX_MS=800
ARCANE_POLL_INTERVAL_MS=250
ARCANE_STALL_TIMEOUT_MS=60000
ARCANE_NAVIGATION_TIMEOUT_MS=30000
ARCANE_RECOVERY_ERROR_COUNT=3
ARCANE_VERIFICATION_DELAY_MIN_MS=700
ARCANE_VERIFICATION_DELAY_MAX_MS=1400
ARCANE_VERIFICATION_MAX_ATTEMPTS=2
