# Required. Used for both Arcane Angler login and Web UI authentication.
ARCANE_USERNAME=your-login-username
ARCANE_PASSWORD=your-password

# Optional Web infrastructure overrides. Gameplay settings are managed in Web UI.
# ARCANE_WEB_HOST=127.0.0.1
# ARCANE_WEB_PORT=3200
# ARCANE_URL=https://arcaneangler.com/
# ARCANE_USER_DATA_DIR=.data/browser
# ARCANE_ARTIFACTS_DIR=artifacts
